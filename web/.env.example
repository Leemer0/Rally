# Safe to expose in the browser. Copy both values from Supabase > Connect.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only. Add this only to local .env.local and Vercel Environment Variables.
# Never prefix this value with NEXT_PUBLIC_ or put it in a URL.
SUPABASE_SECRET_KEY=sb_secret_your_server_key

# The production origin used in Supabase email-confirmation redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Version recorded by the server-only venue registration RPC.
VENUE_AGREEMENT_VERSION=venue-agreement-2026-07

# Authenticated Edge Function that checks private.internal_admins and returns
# { "authorized": true }. Admin access fails closed if this is missing/fails.
SUPABASE_FOUNDER_ACCESS_FUNCTION=founder-access

# Authenticated Edge Function used by the live founder operations pages.
SUPABASE_FOUNDER_DASHBOARD_FUNCTION=founder-dashboard

# Stripe Billing. Prefer a restricted server key with only the Customer,
# Checkout, Price, Portal, and Subscription permissions this app uses.
STRIPE_RESTRICTED_KEY=rk_test_your_restricted_key
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret
STRIPE_PRO_PRICE_ID=price_your_recurring_pro_price

# Resend is used server-side for Outly-owned transactional email. Supabase Auth
# confirmation/recovery messages use the same provider through custom SMTP.
RESEND_API_KEY=re_your_server_key
OUTLY_EMAIL_FROM=Outly <no-reply@getoutly.app>
OUTLY_EMAIL_REPLY_TO=admin@getoutly.app
